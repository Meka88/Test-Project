# Copy this file to .env.local and fill in values as needed.
# .env.local is git-ignored, so it's safe to put real tokens here.

# Meticulous.ai session recording token, used by @alwaysmeticulous/recorder-plugin
# (configured in vite.config.ts) to inject the recorder script tag during local
# development. Get this from your Meticulous project settings.
# Leave unset to run the app without session recording.
VITE_METICULOUS_RECORDING_TOKEN=
